# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Database Names (defaults per service; can be overridden but note that all services will use same if set)
# If you want to use different databases per service, do not set DB_NAME and rely on service-specific defaults in application.yml
# DB_NAME=healthcare_shared

# Eureka Service Discovery
EUREKA_HOST=localhost
EUREKA_USERNAME=eureka
