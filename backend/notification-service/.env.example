# Database Configuration for notification-service
DB_HOST=localhost
DB_PORT=5432
DB_NAME=healthcare_notifications
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Service Discovery
EUREKA_HOST=localhost
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=eureka-secret

# Configuration Server
CONFIG_SERVER_URL=http://localhost:8888

# JWT Security (change this in production to a strong secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-and-make-it-long

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@healthcare.com
MAIL_PASSWORD=changeme